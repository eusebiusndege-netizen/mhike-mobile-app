<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MHike.Pages.RegisterPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="MHike - Register">

	<ScrollView>
		<StackLayout Padding="30" Spacing="20">
			<!-- Header -->
			<StackLayout HorizontalOptions="Center" Spacing="10">
				<Label Text="MHike"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#4CAF50"/>
				<Label Text="Create Your Account"
                       FontSize="16"
                       HorizontalOptions="Center"
                       TextColor="#666"/>
			</StackLayout>

			<!-- Registration Form -->
			<Border BackgroundColor="White"
                   Padding="20"
                   Stroke="LightGray"
                   StrokeThickness="1"
                   StrokeShape="RoundRectangle 10">
				<StackLayout Spacing="15">
					<!-- Username -->
					<StackLayout>
						<Label Text="Username" FontAttributes="Bold"/>
						<Entry Text="{Binding Username}"
                               Placeholder="Choose a username"
                               BackgroundColor="#F5F5F5"/>
					</StackLayout>

					<!-- Email -->
					<StackLayout>
						<Label Text="Email" FontAttributes="Bold"/>
						<Entry Text="{Binding Email}"
                               Placeholder="Enter your email"
                               Keyboard="Email"
                               BackgroundColor="#F5F5F5"/>
					</StackLayout>

					<!-- Password -->
					<StackLayout>
						<Label Text="Password" FontAttributes="Bold"/>
						<Entry Text="{Binding Password}"
                               Placeholder="Create a password"
                               IsPassword="True"
                               BackgroundColor="#F5F5F5"/>
					</StackLayout>

					<!-- Confirm Password -->
					<StackLayout>
						<Label Text="Confirm Password" FontAttributes="Bold"/>
						<Entry Text="{Binding ConfirmPassword}"
                               Placeholder="Confirm your password"
                               IsPassword="True"
                               BackgroundColor="#F5F5F5"/>
					</StackLayout>

					<!-- Error Message -->
					<Label Text="{Binding ErrorMessage}"
                           TextColor="Red"
                           IsVisible="{Binding HasError}"
                           HorizontalOptions="Center"/>

					<!-- Register Button -->
					<Button Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="25"/>

					<!-- Login Link -->
					<StackLayout Orientation="Horizontal" HorizontalOptions="Center">
						<Label Text="Already have an account?"/>
						<Label Text=" Sign In"
                               TextColor="#4CAF50"
                               FontAttributes="Bold">
							<Label.GestureRecognizers>
								<TapGestureRecognizer Command="{Binding NavigateToLoginCommand}"/>
							</Label.GestureRecognizers>
						</Label>
					</StackLayout>
				</StackLayout>
			</Border>
		</StackLayout>
	</ScrollView>
</ContentPage>